  "keyFeatures": [
    "Dynamic tool discovery via MCP protocol",
    "Zero-code API registration through UI or JSON import",
    "Native support for STRING, NUMBER, BOOLEAN, and ARRAY parameter types",
    "OAuth2 and API Key authentication with automatic token refresh",
    "GraalVM native compilation for sub-second startup times",
    "Java 21 Virtual Threads for high concurrency",
    "SQLite database with WAL mode for zero-configuration deployment",
    "Intelligent caching of tool definitions"
  ],
  "publicApiSurface": [
    "GET /mcp/tools/list - Discover available tools",
    "POST /mcp/tools/call - Execute a tool",
    "GET /admin/tools/api - List all registered tools",
    "GET /admin/tools/api/{id} - Get tool details",
    "DELETE /admin/tools/api/{id} - Remove a tool",
    "GET /api/export/providers - Export provider configurations",
    "POST /api/import/providers - Import provider configurations",
    "GET /admin/providers - List API providers",
    "POST /admin/providers - Create new provider",
    "PUT /admin/providers/{id} - Update provider",
    "DELETE /admin/providers/{id} - Delete provider"
  ]
}
